@using RealEstate_Dapper_UI.Dtos.ProductImageDtos
@model List<GetProductImageByProductIdDto>


@foreach (var item in Model)
{
    <div class="item">
        <div class="card">
            <img src="@item.ImageUrl" class="img-fluid radius-image slider-fixed-image" alt="image">
        </div>
    </div>
}