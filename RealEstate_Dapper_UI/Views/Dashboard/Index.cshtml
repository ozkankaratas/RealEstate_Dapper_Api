@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Admin/Index.cshtml";
}

<!-- Sale & Revenue Start -->
@await Component.InvokeAsync("_DashboardStatisticsComponentPartial")
<!-- Sale & Revenue End -->

<!-- Sales Chart Start -->
@await Component.InvokeAsync("_DashboardSalesChartComponentPartial")
<!-- Sales Chart End -->

<!-- Recent Sales Start -->
@await Component.InvokeAsync("_DashboardLastFiveProductsComponentPartial")
<!-- Recent Sales End -->

<!-- Widgets Start -->
<div class="container-fluid pt-4 px-4">
    <div class="row g-4">
        @await Component.InvokeAsync("_DashboardLastFourContactsComponentPartial")

        <div class="col-sm-12 col-md-6 col-xl-4">
            <div class="h-100 bg-light rounded p-4">
                <div class="d-flex align-items-center justify-content-between mb-4">
                    <h6 class="mb-0">Takvim</h6>
                    <a href="">Tümünü Göster</a>
                </div>
                <div id="calender"></div>
            </div>
        </div>

        @await Component.InvokeAsync("_DashboardToDoListComponentPartial")
    </div>
</div>
<!-- Widgets End -->